# Database
# Connection string for your database (PostgreSQL recommended for Prisma)
DATABASE_URL=

# NextAuth.js v5 (Auth.js)
# Generate a secure secret: openssl rand -base64 32
# NextAuth v5 uses AUTH_SECRET (NEXTAUTH_SECRET is the v4 name — keep both for compat)
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

