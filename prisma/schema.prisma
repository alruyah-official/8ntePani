// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Datasource — reads DATABASE_URL from the .env file
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Generator — outputs the Prisma Client to node_modules/@prisma/client
generator client {
  provider = "prisma-client-js"
}

